{
  "id": "nvidia-cuda",
  "version": "1.0.0",
  "name": "NVIDIA CUDA",
  "description": "Installs shared libraries for NVIDIA CUDA.",
  "documentationURL": "https://github.com/jehontan/devcontainer-features/tree/main/src/nvidia-cuda",
  "options": {
    "installCudnn": {
      "type": "boolean",
      "default": false,
      "description": "Additionally install CUDA Deep Neural Network (cuDNN) shared library"
    },
    "installCudnnDev": {
      "type": "boolean",
      "default": false,
      "description": "Additionally install CUDA Deep Neural Network (cuDNN) development libraries and headers"
    },
    "installTrt": {
      "type": "boolean",
      "default": false,
      "description": "Additionally install TensorRT"
    },
    "installNvtx": {
      "type": "boolean",
      "default": false,
      "description": "Additionally install NVIDIA Tools Extension (NVTX)"
    },
    "installToolkit": {
      "type": "boolean",
      "default": false,
      "description": "Additionally install NVIDIA CUDA Toolkit"
    },
    "cudaVersion": {
      "type": "string",
      "proposals": [
